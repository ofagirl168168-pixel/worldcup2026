# Claude Code 設定
.claude/

# 系統檔
.DS_Store
Thumbs.db

# 編輯器設定
.vscode/
*.suo
*.user

# 環境變數（API key 絕對不能上傳）
.env
.env.local
*.env

# Node（之後加 GitHub Actions 會用到）
node_modules/

# 留言審核機器人游標
scripts/.comments-cursor
scripts/.feedback-cursor

# bot stdout/stderr (背景啟動時的 log)
scripts/.bot-stdout.log
scripts/.bot-stderr.log

# opinion-telegram 執行時互斥鎖（內含 PID，comments-bot 用它來讓開 /getUpdates）
scripts/.opinion-telegram.lock
# 排隊檔：前一個 opinion-telegram 還活著時，新進的候選會寫進這、由前一個結束時自動接著跑
scripts/.opinion-telegram-pending.json

# opinion-telegram 背景啟動 log（透過 bot.py 或 PowerShell Start-Process）
scripts/.opinion-7am.log
scripts/.opinion-7am.err
scripts/.opinion-2pm.log
scripts/.opinion-2pm.err

# IG instagrapi session — 本機限定，絕對不能 commit
scripts/.ig-session.json
